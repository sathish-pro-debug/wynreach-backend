{
  "annotations": {"list": []},
  "panels": [
    {
      "type": "graph",
      "title": "Request Rate (per second)",
      "targets": [
        {"expr": "sum by (path) (rate(app_requests_total[1m]))", "legendFormat": "{{path}}"}
      ],
      "id": 1
    },
    {
      "type": "graph",
      "title": "Request Latency (P95)",
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(app_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}"}
      ],
      "id": 2
    },
    {
      "type": "graph",
      "title": "DB Statements (rate)",
      "targets": [
        {"expr": "rate(app_db_statements_total[1m])", "legendFormat": "db_statements"}
      ],
      "id": 3
    }
  ],
  "title": "WynReach Backend Metrics",
  "schemaVersion": 16
}
