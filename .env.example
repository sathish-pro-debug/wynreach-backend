# WynReach Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
MAIN_DB_URL=postgresql://user:password@localhost:5432/wynreach
LOG_DB_URL=postgresql://user:password@localhost:5432/wynreach_logs

# ============================================
# Security
# ============================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================
# Application Settings
# ============================================
APP_NAME=WynReach
DEBUG=True
FRONTEND_URL=http://localhost:5173

# ============================================
# AWS SES Configuration (for email sending)
# ============================================
AWS_ACCESS_KEY_ID=your_ses_access_key
AWS_SECRET_ACCESS_KEY=your_ses_secret_key
AWS_REGION=ap-south-1
SES_FROM_EMAIL=noreply@example.com

# ============================================
# AWS S3 Configuration (for template images)
# ✨ NEW: Required for image upload feature
# ============================================
AWS_ACCESS_KEY_ID_EMAIL=your_s3_access_key
AWS_SECRET_ACCESS_KEY_EMAIL=your_s3_secret_key
AWS_S3_BUCKET=wynreach-template-images
AWS_S3_REGION=ap-south-1

# Image Upload Settings (optional - these are defaults)
MAX_IMAGE_SIZE_MB=10
# Allowed MIME types: image/jpeg, image/png, image/gif, image/webp
ALLOWED_IMAGE_TYPES=["image/jpeg", "image/png", "image/gif", "image/webp"]

# ============================================
# WhatsApp Configuration
# ============================================
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_API_VERSION=v20.0

# ============================================
# AWS S3 Setup Instructions
# ============================================
# 1. Create S3 bucket in AWS Console:
#    - Name: wynreach-template-images
#    - Region: ap-south-1
#    - Block all public access: YES
#
# 2. Create IAM User:
#    - Go to IAM Console
#    - Create user: "wynreach-app"
#    - Attach policy: S3 access to templates/images/*
#
# 3. Generate Access Keys:
#    - Save Access Key ID → AWS_ACCESS_KEY_ID_EMAIL
#    - Save Secret Access Key → AWS_SECRET_ACCESS_KEY_EMAIL
#
# 4. Apply Bucket Policy:
#    {
#      "Version": "2012-10-17",
#      "Statement": [{
#        "Effect": "Allow",
#        "Principal": {
#          "AWS": "arn:aws:iam::ACCOUNT_ID:user/wynreach-app"
#        },
#        "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
#        "Resource": "arn:aws:s3:::wynreach-template-images/templates/images/*"
#      }]
#    }
